# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# In the CLI, setting the LLM provider / models / backend URL / language
# also skips the matching interactive selection step (useful for
# OpenAI-compatible endpoints like opencode or LM Studio, and unattended runs).
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
# Sampling temperature (lower = less run-to-run variation on models that
# honor it). Unset leaves each provider at its default. See the README
# "Reproducibility" note — no setting makes LLM output fully deterministic.
#TRADINGAGENTS_TEMPERATURE=0.0

# ── Robinhood Trading MCP (live brokerage; additive & OFF by default) ──────────
# Connects the agent pipeline to your Robinhood Agentic account via the
# Robinhood Trading MCP (https://agent.robinhood.com/mcp/trading). The whole
# layer is inert unless ENABLED=true.
#
#   - GROUNDING=true → inject your real positions & buying power into the agents
#   - TRADE_MODE     → how the rating becomes an order:
#       off    = grounding only, never place an order
#       manual = propose the order; YOU place it via the "Place order" button (default)
#       auto   = place the order automatically right after the verdict
#   - DRY_RUN=true   → simulate orders only (no order leaves the building)
#
# A real order requires TRADE_MODE in {manual,auto} AND DRY_RUN=false. In manual
# mode the button click is your confirmation; in auto mode orders fire with NO
# per-trade confirmation. You are responsible for every trade your agent places.
# Start with DRY_RUN=true to rehearse safely.
#TRADINGAGENTS_ROBINHOOD_ENABLED=false
#TRADINGAGENTS_ROBINHOOD_GROUNDING=true
#TRADINGAGENTS_ROBINHOOD_TRADE_MODE=manual
#TRADINGAGENTS_ROBINHOOD_DRY_RUN=true
#TRADINGAGENTS_ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
#TRADINGAGENTS_ROBINHOOD_MAX_ORDER_NOTIONAL=1000
#TRADINGAGENTS_ROBINHOOD_DEFAULT_ORDER_NOTIONAL=100
#TRADINGAGENTS_ROBINHOOD_ORDER_TYPE=market
#TRADINGAGENTS_ROBINHOOD_TOKEN_PATH=~/.tradingagents/robinhood_token.json
#TRADINGAGENTS_ROBINHOOD_CALLBACK_PORT=8765
