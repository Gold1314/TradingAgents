# StockAgents web app image (FastAPI + the TradingAgents pipeline).
# Separate from the root Dockerfile, which is the CLI entrypoint.
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /build
COPY . .
# Core package (deps from pyproject) + the web layer (fastapi/uvicorn/supabase).
RUN pip install --no-cache-dir . \
 && pip install --no-cache-dir -r web/requirements.txt

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8000

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Non-root user with a writable home for the data/results cache dirs.
RUN useradd --create-home appuser \
 && install -d -m 0755 -o appuser -g appuser /home/appuser/.tradingagents
USER appuser
WORKDIR /home/appuser/app

COPY --from=builder --chown=appuser:appuser /build .

# Entrypoint seeds the Robinhood OAuth token from $ROBINHOOD_TOKEN_JSON (if set,
# for headless PaaS where the browser OAuth flow can't run) and then binds
# Railway's injected $PORT (falls back to 8000 locally). Single worker: the SSE
# run registry lives in process memory.
ENTRYPOINT ["sh", "web/entrypoint.sh"]
